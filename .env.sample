# -----------------------------------------------------------------------------
# Goose Invest Alert Bot — environment variables
#
# Copy this file to `.env` and fill in the values. The bot won't start without
# the variables marked as REQUIRED. Everything else is optional.
#
# See CONFIG.md for a longer description of each variable.
# -----------------------------------------------------------------------------

# ---- Core (REQUIRED) --------------------------------------------------------

# Telegram bot token. Get it from @BotFather.
TELEGRAM_TOKEN=

# MongoDB connection string, e.g. mongodb://localhost:27017/goose
MONGO_URL=

# Tinkoff Invest API token (stocks). https://www.tinkoff.ru/invest/settings/api/
STOCKS_API_TOKEN=

# Numeric Telegram user ID of the bot owner. Receives admin notifications.
BOSS_TG_ID=

# Either 'development' or 'production'.
NODE_ENV=development


# ---- Optional: error tracking ----------------------------------------------

# Sentry DSN. Leave empty to disable Sentry.
SENTRY_URL=


# ---- Optional: exchange API keys -------------------------------------------
# All exchange keys are read-only / market-data only. Provide only the ones
# you actually need; pricing for the others will be skipped.

BINANCE_APIKEY=
BINANCE_APISECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

LBANK_API_KEY=
LBANK_API_SECRET=


# ---- Optional: forex / fiat conversion -------------------------------------

# Sign up at https://app.currencyapi.com/ to get a free API key.
CURRENCY_CONVERTER_APIKEY=


# ---- Optional: premium subscription payments -------------------------------

# Coinbase Commerce token for crypto-card invoices.
COINBASE_TOKEN=

# Tronscan API key + the TRX wallet address you want to monitor for incoming
# subscription payments. https://docs.tronscan.org/getting-started
TRONSCAN_API_KEY=
TRONSCAN_WALLET_ADDRESS=


# ---- Optional: shutdown announcement ---------------------------------------
# Set SHUTDOWN_MODE=true to silence every handler and reply with the farewell
# in src/middlewares/shutdownMode.ts. Unset to restore the bot.

SHUTDOWN_MODE=


# ---- Optional: testing -----------------------------------------------------

# Telegram user ID used by some self-check probes.
TEST_USER_TG_ID=


# ---- Optional: MongoDB tuning ---------------------------------------------
# Override these only if you know what you're doing. See CONFIG.md.

MONGO_CONNECT_TIMEOUT_MS=
MONGO_SOCKET_TIMEOUT_MS=
MONGO_RETRY_DELAY_MS=
MONGO_RETRY_LOG_THROTTLE_MS=
MONGO_WAIT_LOG_THROTTLE_MS=
MONGO_ERROR_LOG_THROTTLE_MS=
MONGO_BOSS_ALERT_THROTTLE_MS=
MONGO_HEALTHCHECK_PERIOD_MS=
MONGO_STARTUP_MAX_ATTEMPTS=
MONGO_STARTUP_RETRY_DELAY_MS=
